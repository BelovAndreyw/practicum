# ============================================================
# Командный зачёт — шаблон переменных окружения
# ============================================================
# Скопируйте этот файл: cp .env.example .env
# Замените все CHANGE_ME на реальные значения
# НИКОГДА не коммитьте .env в репозиторий!
# ============================================================

# === Database (PostgreSQL) ===
POSTGRES_USER=teamzachet
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=teamzachet
DATABASE_URL=postgresql://teamzachet:CHANGE_ME@postgres:5432/teamzachet

# === Backend ===
SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
BACKEND_DEBUG=true
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# === MinIO (S3-совместимое хранилище) ===
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_MIN_8_CHARS
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=uploads
MINIO_USE_SSL=false

# === Auth / SSO УрФУ ===
SSO_ENABLED=false
SSO_PROVIDER=stub
# Раскомментировать при подключении SSO:
# SSO_OAUTH2_CLIENT_ID=
# SSO_OAUTH2_CLIENT_SECRET=
# SSO_OAUTH2_AUTHORIZE_URL=
# SSO_OAUTH2_TOKEN_URL=
# SSO_OAUTH2_USERINFO_URL=

# === Nginx ===
NGINX_SERVER_NAME=localhost

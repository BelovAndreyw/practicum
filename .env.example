# Пример окружения (без реальных секретов)

# PostgreSQL (docker-compose)
POSTGRES_USER=teamzachet
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=teamzachet
DATABASE_URL=postgresql+asyncpg://teamzachet:CHANGE_ME@postgres:5432/teamzachet

# JWT
SECRET_KEY=CHANGE_ME
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
DEMO_MODE=false

# Redis (опционально)
REDIS_URL=redis://redis:6379/0

# App ports (docker-compose)
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
